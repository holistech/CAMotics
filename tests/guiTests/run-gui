#!/bin/bash
#
# GUI-Smoke-Test: startet camotics headless (unter Xvfb), laedt ein Projekt,
# laesst es die Oberflaeche berechnen und per OpenGL rendern, und beendet es
# dann per SIGTERM.  Erfolg = SAUBERER Exit (Code 0): camotics faengt SIGTERM
# ab (FEATURE_SIGNAL_HANDLER), der QTimer-Poll in QtApp::run beendet die
# Qt-Event-Loop, und die App faehrt regulaer herunter.  Damit verriegelt dieser
# Test auch den sauberen Shutdown.  Harte Terminierung (143) oder Absturz
# (SIGSEGV=139, SIGABRT=134) lassen den Test fehlschlagen.
#
# Treibt die sonst ungetesteten GUI-Module (qt/, view/, value/) plus die
# Simulations-/Rendering-Pipeline.  Benoetigt xvfb-run.
#
set -u
here="$(cd "$(dirname "$0")" && pwd)"

# Unter virtuellem Display re-ausfuehren, falls noch nicht geschehen.
if [ -z "${GUI_TEST_XVFB:-}" ]; then
  if ! command -v xvfb-run >/dev/null 2>&1; then
    echo "xvfb-run not available" >&2
    exit 1
  fi
  export GUI_TEST_XVFB=1
  exec xvfb-run -a -s "-screen 0 1024x768x24" "$0" "$@"
fi

camotics="$here/../../camotics"
project="$1"

"$camotics" "$project" >/dev/null 2>&1 &
pid=$!

sleep 6                       # GUI-Init + Projekt laden + Surface rendern
kill -TERM "$pid" 2>/dev/null
wait "$pid"
ec=$?

if [ "$ec" -eq 0 ]; then
  echo "OK"
  exit 0
fi

if [ "$ec" -eq 143 ]; then
  echo "camotics was killed by SIGTERM (not a clean shutdown), exit $ec" >&2
else
  echo "GUI smoke test crashed with exit $ec" >&2
fi
exit 1
