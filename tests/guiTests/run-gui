#!/bin/bash
#
# GUI smoke test: starts camotics headless (under Xvfb), loads a project,
# has it compute the surface and render it via OpenGL, and then terminates it
# via SIGTERM.  Success = a CLEAN exit (code 0): camotics catches SIGTERM
# (FEATURE_SIGNAL_HANDLER), the QTimer poll in QtApp::run ends the
# Qt event loop, and the app shuts down normally.  This test thereby also
# locks in the clean shutdown.  Hard termination (143) or a crash
# (SIGSEGV=139, SIGABRT=134) makes the test fail.
#
# Exercises the otherwise untested GUI modules (qt/, view/, value/) plus the
# simulation/rendering pipeline.  Requires xvfb-run.
#
set -u
here="$(cd "$(dirname "$0")" && pwd)"

# Re-exec under a virtual display if not already done.
if [ -z "${GUI_TEST_XVFB:-}" ]; then
  if ! command -v xvfb-run >/dev/null 2>&1; then
    echo "xvfb-run not available" >&2
    exit 1
  fi
  export GUI_TEST_XVFB=1
  exec xvfb-run -a -s "-screen 0 1024x768x24" "$0" "$@"
fi

camotics="$here/../../camotics"
project="$1"

"$camotics" "$project" >/dev/null 2>&1 &
pid=$!

sleep 6                       # GUI init + load project + render surface
kill -TERM "$pid" 2>/dev/null
wait "$pid"
ec=$?

if [ "$ec" -eq 0 ]; then
  echo "OK"
  exit 0
fi

if [ "$ec" -eq 143 ]; then
  echo "camotics was killed by SIGTERM (not a clean shutdown), exit $ec" >&2
else
  echo "GUI smoke test crashed with exit $ec" >&2
fi
exit 1
