#!/bin/bash
#
# Test-Wrapper fuer camsim-basierte Simulationstests.
#
# Ruft camsim deterministisch (--threads=1) auf ein .camotics-Projekt auf und gibt
# die stabilen STL-Kennzahlen (siehe stl-metrics.py) nach stdout aus. camsim-eigene
# Ausgaben (Fortschritt/Zeiten, nicht deterministisch) werden unterdrueckt, damit nur
# die Kennzahlen mit den Golden-Files verglichen werden.
#
# Aufruf (aus tests/simTests/test.json):  run-sim <projekt.camotics>
#
set -u
here="$(cd "$(dirname "$0")" && pwd)"
camsim="$here/../../camsim"
metrics="$here/stl-metrics.py"
project="$1"

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

if ! "$camsim" --threads=1 --binary=false "$project" "$tmp" >/dev/null 2>&1; then
  echo "camsim failed on $project" >&2
  exit 1
fi

exec python3 "$metrics" "$tmp"
