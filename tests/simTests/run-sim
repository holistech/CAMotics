#!/bin/bash
#
# Test wrapper for camsim-based simulation tests.
#
# Invokes camsim deterministically (--threads=1) on a .camotics project and prints
# the stable STL metrics (see stl-metrics.py) to stdout. camsim's own output
# (progress/timings, non-deterministic) is suppressed so that only the metrics
# are compared against the golden files.
#
# Usage (from tests/simTests/test.json):  run-sim <project.camotics> [threads]
# threads is optional (default 1 for determinism); 0 exercises the clamp
# guard in Renderer::render (must not hang).
#
set -u
here="$(cd "$(dirname "$0")" && pwd)"
camsim="$here/../../camsim"
metrics="$here/stl-metrics.py"
project="$1"
threads="${2:-1}"

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

if ! "$camsim" --threads="$threads" --binary=false "$project" "$tmp" \
     >/dev/null 2>&1; then
  echo "camsim failed on $project" >&2
  exit 1
fi

exec python3 "$metrics" "$tmp"
